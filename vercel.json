{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    { "source": "/home", "destination": "/", "permanent": true },
    { "source": "/home/", "destination": "/", "permanent": true }
  ],
  "rewrites": [
    {
      "source": "/((?!api/)(?!assets/).*)",
      "destination": "/index.html"
    }
  ]
}
