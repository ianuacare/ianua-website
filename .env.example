# Copia in `.env` per `vercel dev` (locale).
# Produzione: Vercel → Project → Settings → Environment Variables.
# Non committare `.env`.

AI_GATEWAY_API_KEY=
# Opzionale — modello gateway formato provider/nome (es. openai/gpt-4o-mini, openai/gpt-5.4)
AI_GATEWAY_MODEL=openai/gpt-4o-mini

# Form contatti — serverless api/send-contact.ts (solo su Vercel / vercel dev)
RESEND_API_KEY=
# Mittente verificato su Resend (es. onboarding@resend.dev in prova, o dominio verificato)
RESEND_FROM_EMAIL=
# Destinatario delle notifiche modulo (default in codice: info@ianua.it)
CONTACT_NOTIFY_EMAIL=
# Origini extra per CORS (CSV). In locale e domini noti sono già consentiti.
CONTACT_ALLOWED_ORIGINS=

# Se il frontend è servito altrove (es. GitHub Pages) e l’API è su Vercel:
# VITE_CONTACT_API_URL=https://tuo-progetto.vercel.app/api/send-contact
